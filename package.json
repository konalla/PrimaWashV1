{
  "name": "prima-wash",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @prima-wash/contracts && npm run build --workspace @prima-wash/api && npm run build --workspace @prima-wash/web && npm run build --workspace @prima-wash/delivery-relay",
    "check": "npm run check --workspace @prima-wash/contracts && npm run build --workspace @prima-wash/contracts && npm run check --workspace @prima-wash/api && npm run check --workspace @prima-wash/web && npm run check --workspace @prima-wash/mobile && npm run check --workspace @prima-wash/delivery-relay",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "compose:auth-staging": "docker compose -f compose.yaml -f compose.staging-auth.yaml up --build",
    "db:migrate": "npm run migrate --workspace @prima-wash/api",
    "db:smoke": "npm run db:smoke --workspace @prima-wash/api",
    "reconcile:payments": "npm run reconcile:payments --workspace @prima-wash/api --",
    "reconcile:payments:loop": "npm run reconcile:payments:loop --workspace @prima-wash/api --",
    "dev:api": "npm run dev --workspace @prima-wash/api",
    "dev:api:local": "npm run dev:local --workspace @prima-wash/api",
    "dev:mobile": "npm run start --workspace @prima-wash/mobile",
    "dev:mobile:web": "npm run web --workspace @prima-wash/mobile",
    "dev:web": "npm run dev --workspace @prima-wash/web",
    "dev:delivery-relay": "npm run dev --workspace @prima-wash/delivery-relay",
    "test": "npm run test --workspaces --if-present",
    "test:postgres": "npm run test:postgres --workspace @prima-wash/api"
  },
  "engines": {
    "node": ">=22"
  }
}
