{
  "name": "@prima-wash/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "build": "tsc",
    "migrate": "tsx src/db/migrate.ts",
    "db:smoke": "tsx src/db/smoke-test.ts",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@prima-wash/contracts": "0.1.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
